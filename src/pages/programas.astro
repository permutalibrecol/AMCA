---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Nuestros Programas">
    <section style="padding: 40px 20px; max-width: 1000px; margin: 0 auto;">
        <h1 style="text-align: center; color: #1e3a5f;">Nuestros Programas</h1>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 30px;">
            
            <!-- TR1 -->
            <div style="border: 1px solid #ddd; padding: 20px; border-radius: 10px;">
                <h3>TR1 - Agro-Modernización</h3>
                <p>Industrialización de materias primas para insertar a pequeños productores en mercados internacionales.</p>
            </div>
            <!-- TR2 -->
            <div style="border: 1px solid #ddd; padding: 20px; border-radius: 10px;">
                <h3>TR2 - Bioeconomía Circular</h3>
                <p>Valorización de residuos agrícolas transformándolos en productos de alto valor agregado.</p>
            </div>
            <!-- HUB -->
            <div style="border: 1px solid #ddd; padding: 20px; border-radius: 10px;">
                <h3>HUB Global - Educación</h3>
                <p>Formación en inglés y herramientas de Inteligencia Artificial para reducir la brecha digital.</p>
            </div>
            <!-- LOG -->
            <div style="border: 1px solid #ddd; padding: 20px; border-radius: 10px;">
                <h3>LOG - Acceso y Permanencia</h3>
                <p>Eliminación de barreras logísticas para garantizar la participación en programas.</p>
            </div>
            <!-- ALZ -->
            <div style="border: 1px solid #ddd; padding: 20px; border-radius: 10px;">
                <h3>ALZ - Gestión Multilateral</h3>
                <p>Captación de recursos y alianzas estratégicas globales para financiar proyectos.</p>
            </div>

        </div>
    </section>
</BaseLayout>
