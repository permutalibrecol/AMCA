---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Programas" description="Conoce los programas de transformación social de Fundación AMCA: bioeconomía industrial, educación tecnológica y más.">
    <section class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Nuestros Programas</span>
                <h1>Ejes de <span class="highlight">transformación</span></h1>
                <p>Conoce nuestras líneas de acción diseñadas para generar impacto real en los territorios.</p>
            </div>
            
            <!-- Programa 1 -->
            <div class="program-card" style="margin-bottom: 40px; display: grid; grid-template-columns: 1fr 1fr; gap: 30px; align-items: center; background: white; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow);">
                <img src="/images/programa-tr1.jpg" alt="TR1 Agro-Modernización" style="width: 100%; height: 300px; object-fit: cover;" />
                <div style="padding: 30px;">
                    <span class="program-tag">TR1</span>
                    <h2 style="font-size: 1.8rem; margin-bottom: 12px;">Agro-Modernización</h2>
                    <p style="color: var(--color-text-light); font-size: 1.05rem; line-height: 1.7; margin-bottom: 16px;">
                        Industrialización de materias primas agrícolas para mercados internacionales. Instalamos plantas de extracción de aceites esenciales, deshidratación de productos y concentración de pulpas, eliminando intermediarios y generando empleo digno en el campo.
                    </p>
                    <ul style="list-style: none; padding: 0; margin-bottom: 20px;">
                        <li style="padding: 8px 0; border-bottom: 1px solid #e2e8f0;">✅ Maquinaria agrícola ligera y naves de acopio</li>
                        <li style="padding: 8px 0; border-bottom: 1px solid #e2e8f0;">✅ Extracción de aceites esenciales y harinas funcionales</li>
                        <li style="padding: 8px 0;">✅ Inserción en mercados internacionales sin intermediarios</li>
                    </ul>
                </div>
            </div>
            
            <!-- Programa 2 -->
            <div class="program-card" style="margin-bottom: 40px; display: grid; grid-template-columns: 1fr 1fr; gap: 30px; align-items: center; background: white; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow);">
                <img src="/images/programa-tr2.jpg" alt="TR2 Bioeconomía Circular" style="width: 100%; height: 300px; object-fit: cover; order: 2;" />
                <div style="padding: 30px; order: 1;">
                    <span class="program-tag">TR2</span>
                    <h2 style="font-size: 1.8rem; margin-bottom: 12px;">Bioeconomía Circular</h2>
                    <p style="color: var(--color-text-light); font-size: 1.05rem; line-height: 1.7; margin-bottom: 16px;">
                        Valorización de subproductos y residuos agrícolas en empaques biodegradables, bioplásticos compostables y aditivos orgánicos para los sectores farmacéutico y de cosmética sostenible.
                    </p>
                    <ul style="list-style: none; padding: 0; margin-bottom: 20px;">
                        <li style="padding: 8px 0; border-bottom: 1px solid #e2e8f0;">✅ Transformación de mermas de cosecha en bioplásticos</li>
                        <li style="padding: 8px 0; border-bottom: 1px solid #e2e8f0;">✅ Empaques biodegradables para exportación</li>
                        <li style="padding: 8px 0;">✅ Aditivos orgánicos para cosmética y farmacia</li>
                    </ul>
                </div>
            </div>
            
            <!-- Programa 3 -->
            <div class="program-card" style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; align-items: center; background: white; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow);">
                <img src="/images/programa-hub.jpg" alt="Hub Global Educación" style="width: 100%; height: 300px; object-fit: cover;" />
                <div style="padding: 30px;">
                    <span class="program-tag">Hub Global</span>
                    <h2 style="font-size: 1.8rem; margin-bottom: 12px;">Educación Tecnológica</h2>
                    <p style="color: var(--color-text-light); font-size: 1.05rem; line-height: 1.7; margin-bottom: 16px;">
                        Clases en vivo de inglés conversacional y herramientas de Inteligencia Artificial para comunidades vulnerables. Formamos talento bilingüe certificado, listo para ser contratado por empresas nacionales e internacionales.
                    </p>
                    <ul style="list-style: none; padding: 0; margin-bottom: 20px;">
                        <li style="padding: 8px 0; border-bottom: 1px solid #e2e8f0;">✅ Inglés conversacional en tiempo real</li>
                        <li style="padding: 8px 0; border-bottom: 1px solid #e2e8f0;">✅ Herramientas prácticas de Inteligencia Artificial</li>
                        <li style="padding: 8px 0;">✅ Talento bilingüe certificado para empresas</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>