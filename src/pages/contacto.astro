---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contacto">
    <section class="container" style="padding: 40px 0;">
        <h1>Contacto</h1>
        <form action="https://formspree.io/f/meebdewe" method="POST">
            <input type="text" name="name" placeholder="Tu nombre" required style="width:100%; margin-bottom:10px;">
            <input type="email" name="email" placeholder="Tu email" required style="width:100%; margin-bottom:10px;">
            <textarea name="message" placeholder="Mensaje" style="width:100%; margin-bottom:10px;"></textarea>
            <button type="submit" class="btn" style="background:#1e3a5f; color:white;">Enviar</button>
        </form>
    </section>
</BaseLayout>
