---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto" description="Contáctanos para ser aliado, donar o conocer más sobre nuestros programas.">
    <section class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Contáctanos</span>
                <h1>Hablemos de <span class="highlight">transformación</span></h1>
                <p>¿Quieres ser aliado, donar o conocer más? Escríbenos y te responderemos pronto.</p>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; max-width: 1000px; margin: 0 auto;">
                <!-- Datos de contacto -->
                <div>
                    <h3 style="font-size: 1.5rem; margin-bottom: 24px;">📬 Información de contacto</h3>
                    <div style="display: flex; flex-direction: column; gap: 20px;">
                        <div style="display: flex; align-items: center; gap: 16px; padding: 16px; background: white; border-radius: var(--radius); box-shadow: var(--shadow);">
                            <div style="font-size: 2rem;">📍</div>
                            <div>
                                <div style="font-weight: 600;">Dirección</div>
                                <div style="color: var(--color-text-light);">Bogotá D.C., Colombia</div>
                            </div>
                        </div>
                        <div style="display: flex; align-items: center; gap: 16px; padding: 16px; background: white; border-radius: var(--radius); box-shadow: var(--shadow);">
                            <div style="font-size: 2rem;">📧</div>
                            <div>
                                <div style="font-weight: 600;">Correo electrónico</div>
                                <div style="color: var(--color-text-light);"><a href="mailto:contacto@fundacionamca.org" style="color: var(--color-primary);">contacto@fundacionamca.org</a></div>
                            </div>
                        </div>
                        <div style="display: flex; align-items: center; gap: 16px; padding: 16px; background: white; border-radius: var(--radius); box-shadow: var(--shadow);">
                            <div style="font-size: 2rem;">📱</div>
                            <div>
                                <div style="font-weight: 600;">Teléfono</div>
                                <div style="color: var(--color-text-light);">+57 3XX XXX XXXX</div>
                            </div>
                        </div>
                        <div style="display: flex; align-items: center; gap: 16px; padding: 16px; background: white; border-radius: var(--radius); box-shadow: var(--shadow);">
                            <div style="font-size: 2rem;">🕐</div>
                            <div>
                                <div style="font-weight: 600;">Horario de atención</div>
                                <div style="color: var(--color-text-light);">Lunes a viernes · 8:00 AM - 6:00 PM</div>
                            </div>
                        </div>
                    </div>

                    <div style="margin-top: 30px; background: var(--color-primary); color: white; border-radius: var(--radius); padding: 24px; text-align: center;">
                        <p style="font-size: 0.9rem; opacity: 0.8;">✅ Todas las donaciones son deducibles de impuestos en Colombia</p>
                        <p style="font-size: 0.8rem; opacity: 0.6; margin-top: 8px;">Calificada en Régimen Tributario Especial - DIAN</p>
                    </div>
                </div>

                <!-- Formulario (placeholder) -->
                <div>
                    <h3 style="font-size: 1.5rem; margin-bottom: 24px;">✉️ Escríbenos</h3>
                    <form style="display: flex; flex-direction: column; gap: 16px; background: white; padding: 30px; border-radius: var(--radius); box-shadow: var(--shadow);">
                        <div>
                            <label style="display: block; font-weight: 600; margin-bottom: 6px;">Nombre completo</label>
                            <input type="text" placeholder="Tu nombre" style="width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 8px; font-family: inherit;" required />
                        </div>
                        <div>
                            <label style="display: block; font-weight: 600; margin-bottom: 6px;">Correo electrónico</label>
                            <input type="email" placeholder="tu@email.com" style="width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 8px; font-family: inherit;" required />
                        </div>
                        <div>
                            <label style="display: block; font-weight: 600; margin-bottom: 6px;">Asunto</label>
                            <select style="width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 8px; font-family: inherit;">
                                <option>Quiero ser aliado empresarial</option>
                                <option>Quiero donar</option>
                                <option>Quiero ser voluntario</option>
                                <option>Información de programas</option>
                                <option>Otro</option>
                            </select>
                        </div>
                        <div>
                            <label style="display: block; font-weight: 600; margin-bottom: 6px;">Mensaje</label>
                            <textarea rows="4" placeholder="Cuéntanos cómo podemos ayudarte..." style="width: 100%; padding: 12px 16px; border: 1px solid #e2e8f0; border-radius: 8px; font-family: inherit; resize: vertical;"></textarea>
                        </div>
                        <button type="submit" style="background: var(--color-primary); color: white; font-weight: 700; padding: 14px; border: none; border-radius: 8px; font-size: 1.05rem; cursor: pointer;">Enviar mensaje</button>
                        <p style="text-align: center; font-size: 0.85rem; color: var(--color-text-light);">📌 Próximamente: integración con WhatsApp y formulario automático</p>
                    </form>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>