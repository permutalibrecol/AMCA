---
const { title } = Astro.props;
---
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Fundación AMCA</title>
    <style is:global>
        body { font-family: sans-serif; margin: 0; padding: 0; line-height: 1.6; color: #333; }
        .container { width: 90%; max-width: 1000px; margin: 0 auto; }
        img { max-width: 100%; height: auto; display: block; }
        
        /* Estilos móviles */
        header { padding: 20px; background: #fff; text-align: center; border-bottom: 1px solid #eee; }
        nav ul { display: flex; list-style: none; padding: 0; gap: 15px; justify-content: center; flex-wrap: wrap; }
        nav a { text-decoration: none; color: #1e3a5f; font-weight: bold; font-size: 0.9rem; }
        
        @media (max-width: 600px) {
            nav ul { gap: 10px; }
        }
    </style>
</head>
<body>
    <header>
        <a href="/AMCA/" style="display: flex; justify-content: center; margin-bottom: 10px;">
            <img src="/AMCA/images/logo-amca.jpg" alt="Logo" style="width: 120px;">
        </a>
        <nav>
            <ul>
                <li><a href="/AMCA/">Inicio</a></li>
                <li><a href="/AMCA/programas">Programas</a></li>
                <li><a href="/AMCA/transparencia">Transparencia</a></li>
                <li><a href="/AMCA/donaciones">Donar</a></li>
                <li><a href="/AMCA/contacto">Contacto</a></li>
            </ul>
        </nav>
    </header>

    <main class="container" style="padding: 20px 0;">
        <slot />
    </main>

    <footer style="background: #1e3a5f; color: white; text-align: center; padding: 20px; font-size: 0.8rem;">
        <p>&copy; 2026 Fundación AMCA</p>
    </footer>
</body>
</html>
