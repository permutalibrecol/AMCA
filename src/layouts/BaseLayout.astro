---
const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Fundación AMCA</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="fundación social Colombia, bioeconomía, innovación social, inteligencia artificial, impacto social, ESAL, mujeres cabeza de familia" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://fundacionamca.org${Astro.url.pathname}`} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={`${title} · Fundación AMCA`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://fundacionamca.org${Astro.url.pathname}`} />
    <meta property="og:image" content="https://fundacionamca.org/images/og-image.jpg" />
    <meta property="og:site_name" content="Fundación AMCA" />
    <meta property="og:locale" content="es_CO" />
    
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} · Fundación AMCA`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://fundacionamca.org/images/og-image.jpg" />
    
    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NGO",
      "name": "Fundación AMCA",
      "alternateName": "Agro-Modernización y Comunidades Autónomas",
      "url": "https://fundacionamca.org",
      "logo": "https://fundacionamca.org/images/logo-amca.png",
      "foundingDate": "2026",
      "founder": {
        "@type": "Person",
        "name": "Astrid Milena Rondón"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bogotá",
        "addressCountry": "CO"
      },
      "description": "Aceleradora de impacto socioeconómico mediante bioeconomía industrial y educación tecnológica operada con Inteligencia Artificial."
    })} />
    
    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="apple-touch-icon" href="/images/logo-amca.png" />
    
    <!-- Estilos -->
    <link rel="stylesheet" href="/styles/global.css" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>
    <header class="header">
        <div class="container header-inner">
            <a href="/" class="logo">
                <img src="/images/logo-amca.png" alt="Fundación AMCA" class="logo-img" />
                <span class="logo-text">Fundación <strong>AMCA</strong></span>
            </a>
            <nav class="nav">
                <ul class="nav-list">
                    <li><a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>Inicio</a></li>
                    <li><a href="/programas" class={Astro.url.pathname === '/programas' ? 'active' : ''}>Programas</a></li>
                    <li><a href="/transparencia" class={Astro.url.pathname === '/transparencia' ? 'active' : ''}>Transparencia</a></li>
                    <li><a href="/donaciones" class="btn-donar-nav">Donar</a></li>
                    <li><a href="/contacto" class={Astro.url.pathname === '/contacto' ? 'active' : ''}>Contacto</a></li>
                </ul>
            </nav>
            <button class="menu-toggle" id="menuToggle" aria-label="Menú">☰</button>
        </div>
    </header>

    <main>
        <slot />
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <img src="/images/logo-amca-white.png" alt="Fundación AMCA" class="footer-logo" />
                    <p>Agro-Modernización y Comunidades Autónomas</p>
                    <div class="footer-social">
                        <a href="#" aria-label="YouTube">▶️</a>
                        <a href="#" aria-label="LinkedIn">🔗</a>
                        <a href="#" aria-label="Instagram">📷</a>
                        <a href="#" aria-label="Facebook">👍</a>
                    </div>
                </div>
                <div class="footer-links">
                    <h4>Enlaces rápidos</h4>
                    <ul>
                        <li><a href="/">Inicio</a></li>
                        <li><a href="/programas">Programas</a></li>
                        <li><a href="/transparencia">Transparencia</a></li>
                        <li><a href="/donaciones">Donaciones</a></li>
                        <li><a href="/contacto">Contacto</a></li>
                    </ul>
                </div>
                <div class="footer-contact">
                    <h4>Contáctanos</h4>
                    <p>📍 Bogotá D.C., Colombia</p>
                    <p>📧 <a href="mailto:contacto@fundacionamca.org">contacto@fundacionamca.org</a></p>
                    <p>📱 +57 3XX XXX XXXX</p>
                </div>
                <div class="footer-legal">
                    <h4>Legales</h4>
                    <ul>
                        <li><a href="#">Política de privacidad</a></li>
                        <li><a href="#">Términos de uso</a></li>
                        <li><a href="#">Código de ética</a></li>
                    </ul>
                    <p class="footer-rte">✅ Calificada en Régimen Tributario Especial - DIAN</p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Fundación AMCA · Todos los derechos reservados</p>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const menuToggle = document.getElementById('menuToggle');
            const nav = document.querySelector('.nav');
            if (menuToggle && nav) {
                menuToggle.addEventListener('click', function() {
                    nav.classList.toggle('active');
                });
                nav.querySelectorAll('a').forEach(link => {
                    link.addEventListener('click', () => {
                        nav.classList.remove('active');
                    });
                });
            }
        });
    </script>
</body>
</html>