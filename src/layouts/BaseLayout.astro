---
const { title, description } = Astro.props;
---
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Fundación AMCA</title>
    <style is:global>
        /* Diseño móvil por defecto */
        body { font-family: sans-serif; margin: 0; padding: 0; line-height: 1.6; color: #333; }
        .container { width: 90%; max-width: 1000px; margin: 0 auto; overflow: hidden; }
        img { max-width: 100%; height: auto; }
        
        /* Navegación Responsive */
        header { padding: 1rem; background: #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        nav ul { display: flex; list-style: none; padding: 0; gap: 15px; justify-content: center; flex-wrap: wrap; }
        nav a { text-decoration: none; color: #1e3a5f; font-weight: bold; }
        
        /* Botones */
        .btn { padding: 12px 20px; background: #007c70; color: white; text-decoration: none; border-radius: 8px; display: inline-block; margin-top: 10px; }
    </style>
</head>
<body>
    <header>
        <div class="container" style="text-align: center;">
            <a href="/AMCA/"><img src="/AMCA/images/logo-amca.jpg" alt="Logo" style="width: 120px;"></a>
            <nav>
                <ul>
                    <li><a href="/AMCA/">Inicio</a></li>
                    <li><a href="/AMCA/programas">Programas</a></li>
                    <li><a href="/AMCA/transparencia">Transparencia</a></li>
                    <li><a href="/AMCA/donaciones">Donar</a></li>
                    <li><a href="/AMCA/contacto">Contacto</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="container" style="padding: 20px 0;">
        <slot />
    </main>

    <footer style="background: #1e3a5f; color: white; text-align: center; padding: 20px; margin-top: 40px;">
        <p>&copy; 2026 Fundación AMCA</p>
    </footer>
</body>
</html>